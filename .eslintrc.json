{ 
  "env": { 
    "node": true, 
    "es2021": true, 
    "browser": true, 
    "jest": true 
  }, 
  "extends": [ 
    "eslint:recommended", 
    "plugin:prettier/recommended" 
  ], 
  "parserOptions": { 
    "ecmaVersion": "latest", 
    "sourceType": "module" 
  }, 
  "rules": { 
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }], 
    "no-console": ["warn", { "allow": ["warn", "error"] }], 
    "eqeqeq": ["error", "always"], 
    "prefer-const": "error", 
    "no-var": "error", 
    "semi": ["error", "always"], 
    "quotes": ["error", "single"] 
  } 
}